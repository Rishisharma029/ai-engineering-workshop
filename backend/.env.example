# Port for Express API backend
PORT=5000

# JSON Web Token sign key
JWT_SECRET=workspace-developer-jwt-secret-key

# OpenAI API Key (Leave blank to use mock/offline demo mode)
OPENAI_API_KEY=

# Google Gemini API Key (Required for live Gemini assessments)
GEMINI_API_KEY=

# Anthropic Claude API Key (Required for live Claude assessments)
CLAUDE_API_KEY=

# PostgreSQL Database Connection String (Leave blank to automatically use local SQLite fallback)
DATABASE_URL=

# GitHub OAuth App settings (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
